# InsightFlow v2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Application ───────────────────────────────────────────────────────────────
ENV=development                         # development | production
SECRET_KEY=change-me-to-a-random-256-bit-hex-string
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (application data: users, datasets metadata, dashboards, history)
DATABASE_URL=postgresql+asyncpg://insightflow:insightflow@localhost:5432/insightflow

# Redis (LLM cache, rate limiting, session state)
REDIS_URL=redis://localhost:6379/0

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_DIR=./data/users                   # root path for user SQLite databases
MAX_CSV_SIZE_MB=50
MAX_DATASETS_PER_USER=10

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Groq — Primary (fastest, free tier) — https://console.groq.com
GROQ_API_KEY=gsk_your_primary_key_here
GROQ_API_KEY_2=gsk_your_backup_key_here        # optional
GROQ_API_KEY_3=gsk_your_third_key_here         # optional
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — Secondary fallback — https://aistudio.google.com
GEMINI_API_KEY=AIza_your_gemini_key_here
GEMINI_API_KEY_2=AIza_your_gemini_backup_here  # optional
GEMINI_MODEL=gemini-2.0-flash

# Anthropic — Third-tier fallback (optional) — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# OpenAI — Fourth-tier fallback (optional) — https://platform.openai.com
# OPENAI_API_KEY=sk-your_key_here

# ── Authentication ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Observability ─────────────────────────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id   # optional
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
